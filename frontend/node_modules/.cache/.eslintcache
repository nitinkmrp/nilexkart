[{"C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\index.js":"1","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\App.js":"2","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\reportWebVitals.js":"3","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\app\\store.js":"4","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\AdminUsers.js":"5","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\app\\userSlice.js":"6","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\Profile.js":"7","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\Cart.jsx":"8","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\Product.jsx":"9","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\Home.jsx":"10","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\pages\\Shop.jsx":"11","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\components\\Navbar\\Navbar.js":"12","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\components\\Loader\\Loader.jsx":"13","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\components\\Footer\\Footer.jsx":"14","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\services\\userApi.js":"15","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\components\\ShopList.jsx":"16","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\utils\\products.js":"17","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\hooks\\useWindowScrollToTop.js":"18","C:\\Users\\nitin\\Desktop\\react-FSD-project-ecommerce-main\\frontend\\src\\components\\Section.jsx":"19","C:\\Users\\nitin\\Desktop\\react-FSD-project