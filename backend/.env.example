# NilexCart Backend Environment Configuration Template
# Copy this file to '.env' in the same directory and fill in your actual credentials.

# ── Port configuration ──────────────────────────────────────────────
PORT=8888

# ── MongoDB Connection Strings ─────────────────────────────────────
# Replace with your local database URL or Atlas cluster credentials
# For local database, run your local mongod service first
MONGO_URI=mongodb://localhost:27017/nilexcart
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxxx.mongodb.net/nilexcart?retryWrites=true&w=majority

# ── JSON Web Token (JWT) Security ──────────────────────────────────
# Choose a strong secret key for signing auth tokens
JWT_SECRET=super_secure_random_hash_secret_key_change_me_in_production

# ── Third Party APIs (Optional / For Payment Integrations) ─────────
# Razorpay payment gateway credentials
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Cloud Storage (Optional / For Product and Receipt Images) ─────
# Cloudinary credentials for media upload
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Frontend Client URL (For CORS Whitelisting) ───────────────────
CLIENT_URL=http://localhost:3000
